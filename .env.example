APP_NAME="BakeFlow POS"
APP_ENV=local
APP_DEBUG=1
APP_URL=http://localhost:8080
APP_TIMEZONE=Africa/Harare

DB_SQLITE_PATH=/path/to/database/bakeflow.sqlite

# Remote MySQL sync (leave blank to disable sync)
REMOTE_DB_HOST=
REMOTE_DB_PORT=3306
REMOTE_DB_DATABASE=
REMOTE_DB_USERNAME=
REMOTE_DB_PASSWORD=

SYNC_API_KEY=
SYNC_INTERVAL=300
