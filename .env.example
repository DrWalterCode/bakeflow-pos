APP_NAME="BakeFlow POS"
APP_ENV=local
APP_DEBUG=1
APP_URL=https://bakeflow.local
APP_TIMEZONE=Africa/Harare

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bakeflow_pos
DB_USERNAME=root
DB_PASSWORD=

# Remote MySQL sync (leave blank to disable sync)
REMOTE_DB_HOST=
REMOTE_DB_PORT=3306
REMOTE_DB_DATABASE=
REMOTE_DB_USERNAME=
REMOTE_DB_PASSWORD=

SYNC_API_KEY=
SYNC_INTERVAL=300

# Optional QZ Tray signing (leave blank to use unsigned prompts)
QZ_TRAY_CERT_PATH=
QZ_TRAY_CERTIFICATE=
QZ_TRAY_PRIVATE_KEY_PATH=
QZ_TRAY_PRIVATE_KEY=
QZ_TRAY_PRIVATE_KEY_PASSPHRASE=
QZ_TRAY_SIGN_ALGORITHM=SHA256
